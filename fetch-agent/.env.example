# VoxlyAI backend URL
# In Docker Compose use the service name; for standalone use your public backend URL
VOXLY_API_URL=http://localhost:8000

# API key created in VoxlyAI Settings > API Keys (must start with vlx-)
# Create a separate key for this agent — easier to revoke independently
VOXLY_API_KEY=vlx-your-key-here

# Agent identity seed — KEEP SECRET, this determines the agent's permanent address
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
# Losing this seed means losing the agent's identity on Agentverse
AGENT_SEED=your-64-char-hex-seed-change-this

# Agent display name shown on Agentverse
AGENT_NAME=voxlyai-content-generator

# Local port for the agent inspector UI (http://localhost:8002)
AGENT_PORT=8002

# Set to "false" in production to skip the local inspector server
AGENT_INSPECTOR=true

# ── Agentverse setup ────────────────────────────────────────────────────────
# 1. Run the agent once — it will print its address on startup
# 2. Go to https://agentverse.ai and sign in
# 3. Create a new agent → "Connect local agent" → paste the address
# 4. The mailbox is now active; other agents can message this address
# ────────────────────────────────────────────────────────────────────────────
