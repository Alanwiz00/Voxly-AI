# App
APP_ENV=development
# Generate with: openssl rand -base64 32
SECRET_KEY=your-secret-key-min-32-chars-change-this

# Comma-separated admin emails — seeded into allowed_emails on first boot
# Admins can create API keys (vlx-...) for agent-to-agent integrations
ADMIN_EMAILS=you@gmail.com

# PostgreSQL (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.yourproject.supabase.co:5432/postgres

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Firecrawl
FIRECRAWL_API_KEY=fc-your-firecrawl-key

# Tavily
TAVILY_API_KEY=tvly-your-tavily-key

# Auth (must match NEXTAUTH_SECRET in frontend)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# CORS — comma-separated allowed frontend origins
# Production: https://app.yourdomain.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# MCP Server — API key for the VoxlyAI MCP service (Settings > API Keys)
VOXLY_MCP_API_KEY=vlx-your-mcp-server-key

# Fetch.ai uAgent — separate API key and a stable identity seed
# Generate seed with: python -c "import secrets; print(secrets.token_hex(32))"
VOXLY_FETCH_API_KEY=vlx-your-fetch-agent-key
FETCH_AGENT_SEED=your-64-char-hex-seed-change-this
