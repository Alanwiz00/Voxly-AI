# App
APP_ENV=development
# Generate with: openssl rand -base64 32
SECRET_KEY=your-secret-key-min-32-chars-change-this

# Comma-separated admin emails — seeded into allowed_emails on first boot
# Admins can create API keys (vlx-...) for agent-to-agent integrations
ADMIN_EMAILS=you@gmail.com

# PostgreSQL (Supabase)
DATABASE_URL=postgresql+asyncpg://postgres:password@db.yourproject.supabase.co:5432/postgres

# Qdrant Cloud
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your-qdrant-api-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Auth (must match NEXTAUTH_SECRET in frontend)
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars

# CORS — comma-separated allowed frontend origins
# Production: https://app.yourdomain.com,http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# MCP Server — API key for the VoxlyAI MCP service (Settings > API Keys)
VOXLY_MCP_API_KEY=vlx-your-mcp-server-key

# Fetch.ai uAgent — separate API key and a stable identity seed
# Generate seed with: python -c "import secrets; print(secrets.token_hex(32))"
VOXLY_FETCH_API_KEY=vlx-your-fetch-agent-key
FETCH_AGENT_SEED=your-64-char-hex-seed-change-this
# Public HTTPS URL Agentverse uses to deliver messages to this agent
# Set up a domain on Dokploy pointing to fetch-agent:8002, then set it here
FETCH_AGENT_ENDPOINT=https://agent.yourdomain.com/submit
# Agentverse API key — shown on the "Launch your agent" page, copy from there
AGENTVERSE_KEY=your-agentverse-key-here

# Beteye Agent — autonomous World Cup content + auto-poster
# Create a vlx- key in Settings > API Keys, run beteye-agent/setup.py to get PERSONA_ID
BETEYE_API_KEY=vlx-your-beteye-key
BETEYE_PERSONA_ID=                        # printed by setup.py after first run
BETEYE_COLLECT_INTERVAL_MINS=30           # normal collect interval (overridden to 10 on match days)
BETEYE_FALLBACK_POST_HOURS=4              # fallback post interval (primary trigger is collect_job)
BETEYE_POSTS_PER_RUN=4                    # tweets per post run
BETEYE_MIN_QUEUE_THRESHOLD=2              # new items needed to trigger an immediate post
BETEYE_MIN_POST_GAP_MINS=45              # minimum minutes between post runs
BETEYE_BREAKING_SCORE_THRESHOLD=6        # score at which news is treated as breaking (bypasses gap)
BETEYE_DRY_RUN=false                      # set true to generate without posting to X
BETEYE_ENABLE_REPLIES=false               # set true to reply to tracked X accounts' tweets
BETEYE_MAX_CONTENT_AGE_HOURS=2
BETEYE_TRANSCRIPT_MAX_CHARS=2000
BETEYE_MATCHDAY_COLLECT_MINS=10          # collect interval during live match windows
BETEYE_EXTRA_NEWS_FEEDS=                  # comma-separated extra RSS URLs
BETEYE_EXTRA_X_ACCOUNTS=                  # comma-separated extra @handles (without @)
BETEYE_EXTRA_YOUTUBE_CHANNELS=            # comma-separated extra YouTube channel IDs (UCxxxxx)

# X (Twitter) API — required for Beteye auto-posting
# Get these from developer.twitter.com > Your App > Keys and Tokens
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret
