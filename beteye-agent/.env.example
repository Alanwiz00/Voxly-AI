# ============================================================
# Beteye Agent — World Cup Content Bot
# Copy to .env and fill in real values before running.
# ============================================================

# VoxlyAI backend
# URL of the running VoxlyAI API (docker-compose: http://backend:8000)
VOXLY_API_URL=https://voxly-api.yourdomain.com

# vlx- API key — create one in VoxlyAI Settings > API Keys
VOXLY_API_KEY=vlx-your-beteye-key

# World Cup persona ID — printed by setup.py after first run
# Run: python setup.py   to create the persona and topics
PERSONA_ID=

# ============================================================
# Posting schedule
# ============================================================

# How often to check all sources for new content (minutes)
COLLECT_INTERVAL_MINS=30

# How often to post from the queue (hours)
POST_INTERVAL_HOURS=4

# How many tweets to post per posting run
POSTS_PER_RUN=2

# Set to true to generate posts without actually sending to X
DRY_RUN=false

# Only collect content published within the last N hours
MAX_CONTENT_AGE_HOURS=2

# Maximum characters of YouTube transcript to pass to VoxlyAI
TRANSCRIPT_MAX_CHARS=2000

# ============================================================
# X (Twitter) API credentials
# Get these from developer.twitter.com > Your App > Keys and Tokens
# Requires at least the Free tier with write access enabled
# ============================================================

#Consumer Key=0ENwbGhYqiCwCHOhIbsvBliIy
#Secret Key=HfaxrxUz58zGINqX2Kdgh2jtuArKjZp2TYUVaXklXEx3dRE0TO
#Bearer Token=AAAAAAAAAAAAAAAAAAAAAOI2%2BAEAAAAAMc2zFwgB9MI%2F%2FrcvSLK%2F9avw9Pc%3DQN3G1AL3nrD0UhbTbz5ietOzWGNgHWTXfxTT7fYQfLafKEtWTk

X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
X_ACCESS_TOKEN=your-x-access-token
X_ACCESS_TOKEN_SECRET=your-x-access-token-secret

# ============================================================
# Optional — extra sources on top of the built-in defaults
# ============================================================

# Comma-separated RSS feed URLs to add alongside the defaults
EXTRA_NEWS_FEEDS=

# Comma-separated X handles to track (without @)
# e.g. EXTRA_X_ACCOUNTS=FabrizioRomano,OptaJoe
EXTRA_X_ACCOUNTS=

# Comma-separated YouTube channel IDs (UCxxxxxxx format)
# Find the ID at: youtube.com/channel/<ID>
EXTRA_YOUTUBE_CHANNELS=
